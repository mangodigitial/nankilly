# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/nankilly?sslmode=require"

# Square Payments
SQUARE_ACCESS_TOKEN="your-square-access-token"
SQUARE_LOCATION_ID="your-square-location-id"
SQUARE_ENVIRONMENT="sandbox"  # change to "production" when live
SQUARE_WEBHOOK_SIGNATURE_KEY="your-webhook-signature-key"

# Resend Email
RESEND_API_KEY="re_xxxxxxxxxxxxx"
RESEND_FROM_EMAIL="orders@nankilly.com"  # or onboarding@resend.dev for testing
NOTIFY_EMAIL="emily@nankilly.com"

# Admin Auth
ADMIN_JWT_SECRET="generate-a-random-32-char-string-here"

# App
NEXT_PUBLIC_URL="http://localhost:3000"

# Image uploads (using Vercel Blob or similar)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"
